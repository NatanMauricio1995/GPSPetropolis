		{
			"descricao": "Calcula a distância entre dois pontos na superfície da Terra",
			"formula": "d = 2r * arcsin( √[ sin²(Δφ/2) + cos(φ1) * cos(φ2) * sin²(Δλ/2)])"
		},
		
